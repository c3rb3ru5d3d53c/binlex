# Copy this file to `.env` before starting the local docker-compose stack.
#
# Example:
#   cp env.example .env

# minio
# Used by the `minio` service in docker-compose.yml.
# MINIO_ROOT_USER=admin
# MINIO_ROOT_PASSWORD=admin

# binlex-server
# Compose defaults:
#   BINLEX_SERVER_CONFIG=/root/.config/binlex/binlex.toml
# Shared config is mounted from:
#   ./data/config/binlex -> /root/.config/binlex
# Uncomment and use this variable in docker-compose.yml if you want to override it.
# BINLEX_SERVER_CONFIG=/root/.config/binlex/binlex.toml

# binlex-mcp
# Compose defaults:
#   BINLEX_MCP_CONFIG=/root/.config/binlex/binlex-mcp.toml
#   BINLEX_MCP_SAMPLES=/data/binlex-mcp/samples
# Example binlex-mcp.toml samples config:
#   [samples]
#   directory = "/data/binlex-mcp/samples"
#   max_upload_size_bytes = 268435456
# Docker image defaults:
#   BINLEX_MCP_LISTEN=0.0.0.0
#   BINLEX_MCP_PORT=5001
# Shared config is mounted from:
#   ./data/config/binlex -> /root/.config/binlex
# Uncomment and use these variables in docker-compose.yml if you want to override them.
# BINLEX_MCP_CONFIG=/root/.config/binlex/binlex-mcp.toml
# BINLEX_MCP_SAMPLES=/data/binlex-mcp/samples
# BINLEX_MCP_LISTEN=0.0.0.0
# BINLEX_MCP_PORT=5001
