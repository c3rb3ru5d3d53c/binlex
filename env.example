# Copy this file to `.env` before starting the local docker-compose stack.
#
# Example:
#   cp env.example .env

# shared image version
# Compose defaults:
#   BINLEX_VERSION=latest
# Uncomment to pin all local Binlex images to a specific workspace release version.
# BINLEX_VERSION=2.0.0

# minio
# Used by the `minio` service in docker-compose.yml.
# MINIO_ROOT_USER=admin
# MINIO_ROOT_PASSWORD=admin

# binlex-server
# Compose defaults:
#   BINLEX_SERVER_CONFIG=/root/.config/binlex/binlex.toml
#   BINLEX_SERVER_EMBEDDINGS=llvm
# Server config is mounted from:
#   ./data/binlex-server/config -> /root/.config
# Uncomment to override the in-container config path.
# BINLEX_SERVER_CONFIG=/root/.config/binlex/binlex.toml
# Uncomment to override the default embeddings backend passed to binlex-server.
# Set to `none` to disable the default `--embeddings llvm`.
# BINLEX_SERVER_EMBEDDINGS=llvm

# binlex-mcp
# Compose defaults:
#   BINLEX_MCP_CONFIG=/root/.config/binlex/binlex-mcp.toml
#   BINLEX_MCP_SAMPLES=/root/.local/share/binlex/samples
# Example binlex-mcp.toml samples config:
#   [samples]
#   directory = "/root/.local/share/binlex/samples"
#   max_upload_size_bytes = 268435456
# Docker image defaults:
#   BINLEX_MCP_LISTEN=0.0.0.0
#   BINLEX_MCP_PORT=3000
#   BINLEX_MCP_BASE_URL=https://binlex.example.com
# MCP config is mounted from:
#   ./data/binlex-mcp/config -> /root/.config
# MCP local data is mounted from:
#   ./data/binlex-mcp/local -> /root/.local
# Uncomment and use these variables in docker-compose.yml if you want to override them.
# BINLEX_MCP_CONFIG=/root/.config/binlex/binlex-mcp.toml
# BINLEX_MCP_SAMPLES=/root/.local/share/binlex/samples
# BINLEX_MCP_LISTEN=0.0.0.0
# BINLEX_MCP_PORT=3000
# BINLEX_MCP_BASE_URL=http://127.0.0.1:3000
