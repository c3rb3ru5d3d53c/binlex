# Copy this file to `.env` before starting the local docker-compose stack.
#
# Example:
#   cp env.example .env

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Optional: force binlex-server to use a specific config file inside the container.
# BINLEX_SERVER_CONFIG=/data/binlex-server/binlex-server.toml

# Optional: enable these when using the `gpu` compose profile.
# NVIDIA_VISIBLE_DEVICES=all
# NVIDIA_DRIVER_CAPABILITIES=compute,utility
