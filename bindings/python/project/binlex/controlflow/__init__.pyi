class GraphQueue:
    """Track discovery and processing state for instructions, blocks, or functions."""

    def insert_invalid(self, address: int) -> None: ...
    def is_invalid(self, address: int) -> bool: ...
    def valid_addresses(self) -> set[int]: ...
    def invalid_addresses(self) -> set[int]: ...
    def processed_addresses(self) -> set[int]: ...
    def is_valid(self, address: int) -> bool: ...
    def insert_valid(self, address: int) -> None: ...
    def insert_processed_extend(self, addresses: set[int]) -> None: ...
    def insert_processed(self, address: int) -> None: ...
    def is_processed(self, address: int) -> bool: ...
    def enqueue_extend(self, addresses: set[int]) -> None: ...
    def enqueue(self, address: int) -> bool: ...
    def dequeue(self) -> Optional[int]: ...
    def dequeue_all(self) -> set[int]: ...

class Graph:
    def __init__(self, architecture: Architecture, config: Config) -> None: ...
    def instructions(self) -> list[Instruction]: ...
    def blocks(self) -> list[Block]: ...
    def functions(self) -> list[Function]: ...
    def mutations(self) -> int: ...
    @property
    def queue_instructions(self) -> GraphQueue: ...
    @property
    def queue_blocks(self) -> GraphQueue: ...
    @property
    def queue_functions(self) -> GraphQueue: ...
    def set_block(self, address: int) -> bool: ...
    def set_function(self, address: int) -> bool: ...
    def extend_instruction_edges(self, address: int, addresses: set[int]) -> bool: ...
    def get_instruction(self, address: int) -> Instruction | None: ...

__all__: list[str]
