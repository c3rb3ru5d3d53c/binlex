from __future__ import annotations

from typing import Optional

from binlex import Architecture, Config
from binlex.genetics import Chromosome
from binlex.hashing import MinHash32, SHA256, TLSH
from binlex.imaging import Imaging
from binlex.lifters.llvm import Lifter as LlvmLifter
from binlex.lifters.vex import Lifter as VexLifter
from binlex.semantics import InstructionSemantics

class _Lifters:
    def llvm(self) -> LlvmLifter: ...
    def vex(self) -> VexLifter: ...

class Function:
    def __init__(self, address: int, cfg: Graph) -> None: ...
    def address(self) -> int: ...
    def architecture(self) -> Architecture: ...
    def chromosome(self) -> Chromosome | None: ...
    def cyclomatic_complexity(self) -> int: ...
    def average_instructions_per_block(self) -> float: ...
    def blocks(self) -> list[Block]: ...
    def bytes(self) -> bytes | None: ...
    def imaging(self) -> Imaging | None: ...
    def prologue(self) -> bool: ...
    def edges(self) -> int: ...
    def entropy(self) -> float | None: ...
    def number_of_instructions(self) -> int: ...
    def number_of_blocks(self) -> int: ...
    def functions(self) -> dict[int, int]: ...
    def processors(self) -> dict[str, object]: ...
    def processor(self, name: str) -> dict[str, object]: ...
    def tlsh(self) -> TLSH | None: ...
    def sha256(self) -> SHA256 | None: ...
    def minhash(self) -> MinHash32 | None: ...
    def markov(self) -> dict[int, float]: ...
    def size(self) -> int: ...
    def contiguous(self) -> bool: ...
    def end(self) -> int | None: ...
    def print(self) -> None: ...
    def to_dict(self) -> dict[str, object]: ...
    def json(self) -> str: ...
    def lifters(self) -> _Lifters: ...

class BlockJsonDeserializer:
    """Deserialize a serialized block JSON payload into typed accessors."""

    def __init__(self, string: str, config: Config) -> None: ...
    def functions(self) -> dict[int, int]: ...
    def architecture(self) -> Architecture: ...
    def bytes(self) -> bytes: ...
    def address(self) -> int: ...
    def minhash(self) -> MinHash32 | None: ...
    def tlsh(self) -> TLSH | None: ...
    def sha256(self) -> SHA256 | None: ...
    def edges(self) -> int: ...
    def blocks(self) -> set[int]: ...
    def to(self) -> set[int]: ...
    def conditional(self) -> bool: ...
    def entropy(self) -> float | None: ...
    def next(self) -> int | None: ...
    def size(self) -> int: ...
    def number_of_instructions(self) -> int: ...
    def chromosome(self) -> Chromosome | None: ...
    def imaging(self) -> Imaging: ...
    def to_dict(self) -> dict[str, object]: ...
    def json(self) -> str: ...
    def print(self) -> None: ...

