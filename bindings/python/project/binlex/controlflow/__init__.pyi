    def chromosome(self) -> Chromosome | None: ...
    def instructions(self) -> list[Instruction]: ...
    def bytes(self) -> bytes: ...
    def imaging(self) -> Imaging: ...
    def prologue(self) -> bool: ...
    def edges(self) -> int: ...
    def next(self) -> int | None: ...
    def to(self) -> set[int]: ...
    def entropy(self) -> float | None: ...
    def blocks(self) -> set[int]: ...
    def number_of_instructions(self) -> int: ...
    def functions(self) -> dict[int, int]: ...
    def processors(self) -> dict[str, object]: ...
    def processor(self, name: str) -> dict[str, object]: ...
    def tlsh(self) -> TLSH | None: ...
    def sha256(self) -> SHA256 | None: ...
    def minhash(self) -> MinHash32 | None: ...
