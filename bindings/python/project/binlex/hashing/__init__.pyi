    def compare_hexdigest(self, other: str, mininum_byte_size: int) -> Optional[float]: ...
    @staticmethod
    def compare_hexdigests(lhs: str, rhs: str) -> Optional[float]: ...


__all__ = ["AHash", "DHash", "MinHash32", "PHash", "SHA256", "TLSH"]
