from __future__ import annotations

from typing import Optional


class AHash:
    def __init__(self, bytes: bytes) -> None: ...
    def hexdigest(self) -> Optional[str]: ...
    def vector(self) -> Optional[list[float]]: ...
    def compare(self, other: AHash) -> Optional[float]: ...
    def compare_hexdigest(self, other: str) -> Optional[float]: ...
    @staticmethod
    def compare_hexdigests(lhs: str, rhs: str) -> Optional[float]: ...


